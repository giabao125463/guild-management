# Environment template for Guild Management System
# Copy to apps/api/.env and apps/web/.env.local as needed

# --- API (apps/api/.env) ---
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://guild:guild@127.0.0.1:5432/guild_management?schema=public
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_DAYS=7
CORS_ORIGIN=http://localhost:3000

# Production examples:
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/guild_management?sslmode=require
# REDIS_URL=rediss://default:pass@xxx.upstash.io:6379
# CORS_ORIGIN=https://your-app.vercel.app

# --- Web (apps/web/.env.local) ---
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Production:
# NEXT_PUBLIC_API_URL=https://your-api.onrender.com/api

# --- Docker Compose overrides ---
# JWT_SECRET=
# CORS_ORIGIN=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:4000/api
