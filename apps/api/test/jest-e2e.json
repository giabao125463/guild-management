{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@guild/shared-types$": "<rootDir>/../../../packages/shared-types/src/index.ts",
    "^@guild/shared-utils$": "<rootDir>/../../../packages/shared-utils/src/index.ts"
  }
}
